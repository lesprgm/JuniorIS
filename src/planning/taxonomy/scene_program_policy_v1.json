  "completion_rules": [
    {
      "rule_id": "sleep_bedside_support",
      "when_slot_concepts_any": [
        "bed"
      ],
      "unless_negative_constraints": [
        "no_bedside",
        "no_nightstand",
        "avoid_bedside_support"
      ],
      "unless_slot_concepts": [
        "nightstand"
      ],
      "slot": {
        "slot_id": "bedside_support_1",
        "concept": "nightstand",
        "priority": "should",
        "runtime_role_hint": "table",
        "rationale": "support sleep anchor with a reachable bedside surface",
        "capabilities": [
          "bedside_support",
          "reachable_surface"
        ]
      }
    },
    {
      "rule_id": "sleep_storage_support",
      "when_slot_concepts_any": [
        "bed"
      ],
      "unless_negative_constraints": [
        "no_storage",
        "avoid_storage"
      ],
      "unless_slot_concepts": [
        "dresser"
      ],
      "slot": {
        "slot_id": "sleep_storage_1",
        "concept": "dresser",
        "priority": "should",
        "runtime_role_hint": "cabinet",
        "rationale": "make the sleeping room feel complete with storage",
        "capabilities": [
          "storage_low"
        ]
      }
    },
    {
      "rule_id": "work_surface_support",
      "when_prompt_tokens_any": [
        "work",
        "study",
        "office",
        "desk"
      ],
      "when_slot_concepts_any": [
        "desk",
        "work_surface"
      ],
      "when_mode": "any",
      "unless_slot_concepts": [
        "desk"
      ],
      "slot": {
        "slot_id": "work_surface_1",
        "concept": "desk",
        "priority": "should",
        "runtime_role_hint": "table",
        "rationale": "cover the room's work function with a primary work surface",
        "capabilities": [
          "work_surface"
        ]
      }
    },
    {
      "rule_id": "display_lounge_support",
      "when_prompt_tokens_any": [
        "museum",
        "gallery",
        "display",
        "exhibit",
        "lounge"
      ],
      "when_slot_concepts_any": [
        "media_console",
        "display_surface"
      ],
      "when_mode": "any",
      "unless_slot_concepts": [
        "display_surface",
        "media_console",
        "nightstand",
        "desk"
      ],
      "slot": {
        "slot_id": "display_support_1",
        "concept": "display_surface",
        "priority": "should",
        "runtime_role_hint": "table",
        "rationale": "support the focal display or lounge composition with one clear support surface",
        "capabilities": [
          "display_support"
        ]
      }
    }
