{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorldSpec v0 (prototype-minimal)",
  "type": "object",
  "required": [
    "worldspec_version",
    "template_id",
    "seed"
  ],
  "properties": {
    "worldspec_version": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "seed": {
      "type": "integer"
    },
    "stylekit_id": {
      "type": "string"
    },
    "pack_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [ "asset_id", "transform" ],
        "properties": {
          "asset_id": { "type": "string" },
          "transform": { "type": "object" },
          "constraint": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["floor", "against_wall", "near", "wall", "surface", "ceiling"]
              },
              "target": { "type": "string" },
              "distance": { "type": "number", "minimum": 0.5, "maximum": 2.5 }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "budgets": {
      "type": "object",
      "properties": {
        "max_props": { "type": "integer" },
        "max_props_hard": { "type": "integer" },
        "max_floor_objects": { "type": "integer" },
        "max_wall_objects": { "type": "integer" },
        "max_surface_objects": { "type": "integer" },
        "max_texture_tier": { "type": "integer" },
        "max_lights": { "type": "integer" },
        "max_clutter_weight": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "layout_program": {
      "type": "object",
      "additionalProperties": true
    },
    "optional_additions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "colors": {
      "type": "object",
      "properties": {
        "wall": { "type": "string" },
        "floor": { "type": "string" },
        "ceiling": { "type": "string" },
        "accent": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
