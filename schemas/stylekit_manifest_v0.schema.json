{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StyleKit Manifest v0 (MVP)",
  "type": "object",
  "required": [
    "stylekit_id",
    "version",
    "tags",
    "lighting",
    "palette"
  ],
  "properties": {
    "stylekit_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lighting": {
      "type": "object",
      "required": ["preset", "intensity"],
      "properties": {
        "preset": { "type": "string" },
        "intensity": { "type": "number" }
      },
      "additionalProperties": true
    },
    "palette": {
      "type": "object",
      "required": ["wall", "floor", "accent"],
      "properties": {
        "wall": { "type": "string" },
        "floor": { "type": "string" },
        "accent": { "type": "string" }
      },
      "additionalProperties": true
    },
    "skybox": { "type": "string" },
    "ambience": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["clip_id"],
          "properties": {
            "clip_id": { "type": "string", "minLength": 1 },
            "volume": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          },
          "additionalProperties": true
        }
      ]
    },
    "decals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decal_id", "max_count"],
        "properties": {
          "decal_id": { "type": "string", "minLength": 1 },
          "max_count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "postfx": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["profile_id"],
          "properties": {
            "profile_id": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      ]
    },
    "perf_overrides": { "type": "object" }
  },
  "additionalProperties": true
}
